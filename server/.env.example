# Airtable (same base as frontend)
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX
AIRTABLE_SUPPLIER_ORDERS_TABLE_ID=tblXXXXXXXXXXXXXX
AIRTABLE_SUPPLIERS_TABLE_ID=tblXXXXXXXXXXXXXX
AIRTABLE_ORDER_FORM_FIELD=טופס הזמנה
AIRTABLE_SUPPLIERS_EMAIL_FIELD=מייל

# Google Drive folder + Docs template (always required)
GOOGLE_DRIVE_FOLDER_ID=XXXXXXXXXXXXXXXX
GOOGLE_DOCS_TEMPLATE_ID=XXXXXXXXXXXXXXXX
AIRTABLE_ORDER_REFERENCE_FIELD=reference

# --- Google auth: OAuth (recommended for personal Gmail; uses YOUR Drive quota) ---
# 1) Cloud Console → APIs: enable Drive API + Google Docs API
# 2) OAuth consent screen + OAuth client (Web). Authorized redirect URIs must include EXACTLY:
#    http://localhost:3001/api/google/oauth/callback   (local)
#    https://YOUR-RAILWAY-URL/api/google/oauth/callback   (production)
GOOGLE_OAUTH_CLIENT_ID=xxx
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxx
# Must match one of the redirect URIs registered on the OAuth client
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/google/oauth/callback
# Long random string; required to open /api/google/oauth/start
GOOGLE_OAUTH_SETUP_KEY=change-me-to-a-long-random-secret
# After one-time browser flow, paste the token Google shows:
# GOOGLE_OAUTH_REFRESH_TOKEN=1//0xxxxx

# If GOOGLE_OAUTH_REFRESH_TOKEN is set, the server uses OAuth. To force service account instead:
# GOOGLE_AUTH_MODE=service_account

# --- Google auth: service account (optional; Shared Drive or quota limits apply) ---
# GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Your Company <your-email@example.com>"

PORT=3001

# --- Quote form → Airtable + n8n ---
AIRTABLE_QUOTES_TABLE_ID=tblXXXXXXXXXXXXXX
# Interface page id (pag…) for “open record” after submit — from the Interface URL, not the table id
# AIRTABLE_QUOTE_INTERFACE_PAGE_ID=pagXXXXXXXXXXXXXX
# Reference column (formula/autonumber in Airtable). Used only to scan existing values for QT-N prediction on success page / n8n — not written by the API.
AIRTABLE_QUOTE_REFERENCE_FIELD=reference
# QUOTE_REFERENCE_PREFIX=QT
# QUOTE_REFERENCE_NUMBER_PAD=5
# QUOTE_REFERENCE_MAX_SCAN_PAGES=30
# Writable quote fields (override if your base uses different names)
# QUOTE_FIELD_DESCRIPTION=תיאור
# QUOTE_FIELD_CUSTOMER=לקוח
# QUOTE_FIELD_CONTACT=איש קשר
# Linked Employees table — who created the quote (required)
# QUOTE_FIELD_CREATED_BY=fldXXXXXXXXXXXXXX
# Optional text mirror fields (names for easier reading in Airtable):
# QUOTE_FIELD_CUSTOMER_NAME_TEXT=שם לקוח
# QUOTE_FIELD_CONTACT_NAME_TEXT=שם איש קשר
# QUOTE_FIELD_CREATED_BY_NAME_TEXT=נוצר על ידי (שם)
# QUOTE_FIELD_TRANSPORTING=הובלה ותוספות
# QUOTE_FIELD_NOTES=הערות
# QUOTE_FIELD_PRODUCTS_JSON=תוצרים
# תוצרים (פסקה עם תיאור+מחיר) נכתבים לשדה QUOTE_FIELD_PRODUCTS_JSON בלבד (לא משולבים בתיאור).
# QUOTE_FIELD_PRICE=מחיר
# If you only have one number column for amount (total incl. VAT), set:
# QUOTE_PRICE_USES_TOTAL_WITH_TAX=true
# QUOTE_OMIT_TAX_FIELDS=true
# (Otherwise מחיר = before tax; optional מעמ / סהכ columns:)
# QUOTE_FIELD_TAX_PRICE=מעמ
# QUOTE_FIELD_TOTAL_WITH_TAX=סהכ כולל מעמ
# QUOTE_FIELD_PAYMENT_CONDITIONS=תנאי תשלום
# QUOTE_FIELD_PAYMENT_DEADLINE=מועד תשלום
# QUOTE_FIELD_SKETCH_DEADLINE=מועד מסירת סקיצה
# QUOTE_FIELD_PROJECT_DEADLINE=מועד פרויקט
# QUOTE_FIELD_DELIVERY_TO_CLIENT=הובלה ללקוח
# QUOTE_FIELD_INTERNAL_NOTES=הערות פנימיות
# QUOTE_FIELD_SEND_TO_CLIENT=שליחה ללקוח
# Date field (optional): set to submit day when send_to_client is true
# QUOTE_FIELD_SENT_TO_CLIENT_DATE=fldXXXXXXXXXXXXXX
# QUOTE_FIELD_SEND_TO_CLIENT_EMAIL_ADDITIONS=תוספות לגוף המייל (שליחה ללקוח)
# תאריך/שעה ב-Airtable לרוב מחושבים — לא לכתוב אלא אם:
# QUOTE_WRITE_CREATED_AT_TO_AIRTABLE=true
# QUOTE_FIELD_CREATED_AT=תאריך יצירה
# QUOTE_FIELD_HOUR=שעה
# אימייל/טלפון לא נשמרים ב-Airtable כברירת מחדל (רק ב-n8n). לאפשר שמירה בטבלת הצעות:
# QUOTE_WRITE_EMAIL_PHONE_TO_AIRTABLE=true
# QUOTE_FIELD_EMAIL=אימייל
# QUOTE_FIELD_PHONE=טלפון
N8N_QUOTE_WEBHOOK_URL=https://your-n8n.example/webhook/quote
# N8N_QUOTE_WEBHOOK_SECRET=optional-shared-secret
# If Quotes table has no tax/total columns, skip writing them:
# QUOTE_OMIT_TAX_FIELDS=true
